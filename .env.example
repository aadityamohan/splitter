# Firebase (Firestore) — optional; app works with localStorage only
# Firebase Console → Project settings → Your apps → Web app config
# If sign-in fails with auth/configuration-not-found: Authentication → Get started,
# enable Google, and ensure these values are from the SAME project (authDomain required).
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
# Optional — enables Google Analytics in the Firebase console
VITE_FIREBASE_MEASUREMENT_ID=
# Optional — if Firestore shows "unavailable" / WebChannel errors, try: true
VITE_FIRESTORE_FORCE_LONG_POLLING=

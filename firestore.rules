rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Any signed-in Firebase user (enable only Google in Auth console for this app).
    // Avoid requiring sign_in_provider == 'google.com' — some tokens differ and deny all reads.
    function isSignedIn() {
      return request.auth != null;
    }

    function emailLower() {
      return request.auth.token.email != null
        ? request.auth.token.email.lower()
        : '';
    }

    function groupDoc(groupId) {
      return get(/databases/$(database)/documents/groups/$(groupId));
    }

    function isGroupMember(groupId) {
      return isSignedIn() && request.auth.uid in groupDoc(groupId).data.memberIds;
    }

    function pendingInviteIdForMe(groupId) {
      return groupId + '|' + emailLower();
    }

    // True when this signed-in user has a mail invite row for this group (same id as client writes).
    function hasPendingInviteForGroup(groupId) {
      return exists(/databases/$(database)/documents/mailInvites/$(emailLower())/items/$(pendingInviteIdForMe(groupId)))
        && get(/databases/$(database)/documents/mailInvites/$(emailLower())/items/$(pendingInviteIdForMe(groupId))).data.groupId == groupId;
    }

    // Per-user group id list — list queries on `groups` with array-contains often get
    // permission-denied even when get() on each group would succeed; this index is safe to list.
    match /userGroups/{userId}/groups/{groupId} {
      allow read, create, delete: if isSignedIn() && request.auth.uid == userId;
      allow update: if false;
    }

    match /groups/{groupId} {
      // Members can read; invitees must read the group doc to run accept (transaction.get).
      allow read: if isSignedIn() && (
        request.auth.uid in resource.data.memberIds
        || hasPendingInviteForGroup(groupId)
      );

      allow create: if isSignedIn()
        && request.auth.uid == request.resource.data.createdBy
        && request.auth.uid in request.resource.data.memberIds
        && request.resource.data.memberIds.size() == 1;

      allow update: if isSignedIn() && (
        isGroupMember(groupId)
        || (
          !(request.auth.uid in resource.data.memberIds)
          && request.auth.uid in request.resource.data.memberIds
          && request.resource.data.memberIds.hasAll(resource.data.memberIds)
          && request.resource.data.memberIds.size() == resource.data.memberIds.size() + 1
          && hasPendingInviteForGroup(groupId)
        )
      );

      allow delete: if isSignedIn() && request.auth.uid == resource.data.createdBy;

      match /participants/{pid} {
        allow read, write: if isGroupMember(groupId);
      }
      match /expenses/{eid} {
        allow read, write: if isGroupMember(groupId);
      }
      match /settlements/{sid} {
        allow read, write: if isGroupMember(groupId);
      }
      match /members/{mid} {
        allow read: if isGroupMember(groupId);
        allow create: if isSignedIn() && (
          (request.auth.uid == mid && isGroupMember(groupId))
          || (
            request.auth.uid == mid
            && !(request.auth.uid in groupDoc(groupId).data.memberIds)
            && hasPendingInviteForGroup(groupId)
          )
        );
        allow update, delete: if isGroupMember(groupId);
      }
      match /outboundInvites/{outId} {
        allow read: if isGroupMember(groupId);
        allow create, update: if isGroupMember(groupId);
        // Invitee declining must delete outbound before they’re a member; allow if their mail invite still exists.
        allow delete: if isGroupMember(groupId)
          || (isSignedIn()
            && exists(/databases/$(database)/documents/mailInvites/$(emailLower())/items/$(outId)));
      }
    }

    // Invites keyed by path so list reads are allowed: emailKey must match signed-in user's email.
    match /mailInvites/{emailKey}/items/{inviteId} {
      allow read: if isSignedIn() && emailKey == emailLower();

      allow create: if isSignedIn()
        && emailKey == request.resource.data.emailLower
        && request.auth.uid in groupDoc(request.resource.data.groupId).data.memberIds
        && request.resource.data.invitedBy == request.auth.uid;

      allow delete: if isSignedIn() && (
        emailKey == emailLower()
        || request.auth.uid in groupDoc(resource.data.groupId).data.memberIds
      );

      allow update: if false;
    }
  }
}

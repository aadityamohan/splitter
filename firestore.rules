rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function emailLower() {
      return request.auth.token.email != null
        ? request.auth.token.email.lower()
        : '';
    }

    function phoneNumber() {
      return request.auth.token.phone_number != null
        ? request.auth.token.phone_number
        : '';
    }

    // ── Membership check via userGroups index (cheap exists(), no get()) ──────
    // userGroups/{uid}/groups/{groupId} is written when a user joins a group,
    // so this is always consistent and avoids expensive get() calls inside rules.
    function isGroupMember(groupId) {
      return isSignedIn()
        && exists(/databases/$(database)/documents/userGroups/$(request.auth.uid)/groups/$(groupId));
    }

    // ── Email invite helpers ──────────────────────────────────────────────────

    function pendingInviteIdForMe(groupId) {
      return groupId + '|' + emailLower();
    }

    function hasPendingInviteForGroup(groupId) {
      return emailLower() != ''
        && exists(/databases/$(database)/documents/mailInvites/$(emailLower())/items/$(pendingInviteIdForMe(groupId)));
    }

    // ── Phone invite helpers ──────────────────────────────────────────────────

    function pendingPhoneInviteIdForMe(groupId) {
      return groupId + '|' + phoneNumber();
    }

    function hasPendingPhoneInviteForGroup(groupId) {
      return phoneNumber() != ''
        && exists(/databases/$(database)/documents/phoneInvites/$(phoneNumber())/items/$(pendingPhoneInviteIdForMe(groupId)));
    }

    function hasAnyPendingInviteForGroup(groupId) {
      return hasPendingInviteForGroup(groupId) || hasPendingPhoneInviteForGroup(groupId);
    }

    // ── Per-user group index ──────────────────────────────────────────────────

    match /userGroups/{userId}/groups/{groupId} {
      allow read, create, update, delete: if isSignedIn() && request.auth.uid == userId;
    }

    // ── FCM push tokens ───────────────────────────────────────────────────────

    match /userTokens/{userId}/tokens/{tokenId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }

    // ── Groups ────────────────────────────────────────────────────────────────

    match /groups/{groupId} {
      // Members read via userGroups index; invitees must read to run the accept transaction.
      allow read: if isSignedIn() && (
        isGroupMember(groupId)
        || hasAnyPendingInviteForGroup(groupId)
      );

      allow create: if isSignedIn()
        && request.auth.uid == request.resource.data.createdBy
        && request.auth.uid in request.resource.data.memberIds
        && request.resource.data.memberIds.size() == 1;

      // Members can update; also allows the join-via-invite write (add self to memberIds).
      allow update: if isSignedIn() && (
        isGroupMember(groupId)
        || (
          !(request.auth.uid in resource.data.memberIds)
          && request.auth.uid in request.resource.data.memberIds
          && request.resource.data.memberIds.hasAll(resource.data.memberIds)
          && request.resource.data.memberIds.size() == resource.data.memberIds.size() + 1
          && hasAnyPendingInviteForGroup(groupId)
        )
      );

      allow delete: if isSignedIn() && request.auth.uid == resource.data.createdBy;

      match /participants/{pid} {
        allow read, write: if isGroupMember(groupId);
      }

      match /expenses/{eid} {
        allow read, write: if isGroupMember(groupId);
      }

      match /settlements/{sid} {
        allow read, write: if isGroupMember(groupId);
      }

      match /members/{mid} {
        allow read: if isGroupMember(groupId);
        // Members add their own profile; invitees add theirs during accept.
        allow create: if isSignedIn() && request.auth.uid == mid && (
          isGroupMember(groupId)
          || hasAnyPendingInviteForGroup(groupId)
        );
        allow update, delete: if isGroupMember(groupId);
      }

      match /outboundInvites/{outId} {
        allow read: if isGroupMember(groupId);
        allow create, update: if isGroupMember(groupId);
        // Invitee can delete (decline) before they are a member.
        allow delete: if isGroupMember(groupId)
          || (isSignedIn()
            && exists(/databases/$(database)/documents/mailInvites/$(emailLower())/items/$(outId)))
          || (isSignedIn()
            && phoneNumber() != ''
            && exists(/databases/$(database)/documents/phoneInvites/$(phoneNumber())/items/$(outId)));
      }
    }

    // ── Email invites ─────────────────────────────────────────────────────────

    match /mailInvites/{emailKey}/items/{inviteId} {
      allow read: if isSignedIn() && emailKey == emailLower();

      // Only a group member can invite.
      allow create: if isSignedIn()
        && emailKey == request.resource.data.emailLower
        && isGroupMember(request.resource.data.groupId)
        && request.resource.data.invitedBy == request.auth.uid;

      // The invitee or any group member can delete (accept / cancel).
      allow delete: if isSignedIn() && (
        emailKey == emailLower()
        || isGroupMember(resource.data.groupId)
      );

      allow update: if false;
    }

    // ── Phone invites ─────────────────────────────────────────────────────────

    match /phoneInvites/{phone}/items/{inviteId} {
      allow read: if isSignedIn() && phone == phoneNumber();

      allow create: if isSignedIn()
        && phone == request.resource.data.phone
        && isGroupMember(request.resource.data.groupId)
        && request.resource.data.invitedBy == request.auth.uid;

      allow delete: if isSignedIn() && (
        phone == phoneNumber()
        || isGroupMember(resource.data.groupId)
      );

      allow update: if false;
    }
  }
}
